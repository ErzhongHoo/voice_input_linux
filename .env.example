# 默认使用 mock ASR，便于没有 Access Key 时验证完整闭环。
VOICE_INPUT_ASR=mock
VOICE_INPUT_MOCK_TEXT=这是一次语音输入测试。

# 设置为 doubao / bigmodel 后使用豆包大模型流式 ASR。
# VOICE_INPUT_ASR=doubao
DOUBAO_ASR_ENDPOINT=wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async
DOUBAO_ASR_APP_KEY=
DOUBAO_ASR_ACCESS_KEY=
DOUBAO_ASR_ACCESS_TOKEN=
DOUBAO_ASR_RESOURCE_ID=volc.seedasr.sauc.duration
# 识别模式：realtime_final / realtime / stream_input / custom
# realtime_final=实时+二遍识别；realtime=实时逐字；stream_input=整句返回。
DOUBAO_ASR_MODE=realtime_final
# 模型侧后处理：关闭 ENABLE_PUNC 后，豆包 ASR 不再主动预测标点。
DOUBAO_ASR_ENABLE_PUNC=true
DOUBAO_ASR_ENABLE_ITN=true
DOUBAO_ASR_ENABLE_DDC=false
# 双向流式优化版的二遍识别：实时出字后再用分句音频复识别，提高最终结果准确率。
DOUBAO_ASR_ENABLE_NONSTREAM=true

# 快捷键。Right Alt 在部分键盘布局上会表现为 AltGr。
VOICE_INPUT_HOTKEY_BACKEND=auto
VOICE_INPUT_HOTKEY_KEY=right_alt
VOICE_INPUT_EVDEV_KEY=KEY_RIGHTALT
# VOICE_INPUT_EVDEV_DEVICE=/dev/input/event3

# 如果已使用 KDE/GNOME/Sway/Hyprland 全局快捷键调用 CLI toggle，可设为 none，避免双触发。
# VOICE_INPUT_HOTKEY_BACKEND=none

# 文本输入 backend：auto / fcitx5 / xdotool / wtype / ydotool / clipboard
VOICE_INPUT_INJECTOR_BACKEND=auto
VOICE_INPUT_PREFER_FCITX5=true
VOICE_INPUT_PASTE_AT_MOUSE=true
# 粘贴快捷键：ctrl+v / ctrl+shift+v / shift+insert
VOICE_INPUT_PASTE_HOTKEY=ctrl+v
# 应用侧后处理：true=末尾无标点时补句号；false=不补，并删除 ASR 返回的最终句号。
VOICE_INPUT_APPEND_FINAL_PUNCTUATION=true

# 音频输入：默认设备，16kHz / mono / PCM int16 little-endian。
VOICE_INPUT_SAMPLE_RATE=16000
VOICE_INPUT_CHANNELS=1
VOICE_INPUT_CHUNK_MS=200
# VOICE_INPUT_DEVICE=10

VOICE_INPUT_OVERLAY_THEME=auto
VOICE_INPUT_LOG_LEVEL=INFO
# VOICE_INPUT_RUNTIME_SOCKET=/run/user/1000/voice-input-linux.sock
# VOICE_INPUT_CONFIG_FILE=/home/user/.config/voice-input-linux.env
